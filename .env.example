# AI Configuration
# 留空、auto：按 API Key 自动选择，优先级 deepseek → glm → gemini → openai
# 也可显式指定其一：deepseek | glm | gemini | openai
AI_PROVIDER="YOUR_AI_PROVIDER"

# API Keys（建议至少配置 DEEPSEEK_API_KEY 或 GLM_API_KEY）
GEMINI_API_KEY="MY_GEMINI_API_KEY"
DEEPSEEK_API_KEY=""
GLM_API_KEY=""
OPENAI_API_KEY=""

# 智谱文本模型（OpenAI 兼容接口），默认 glm-4.7
# GLM_TEXT_MODEL="YOUR_MODEL"

# 服务端 TTS（默认 edge-tts，免费，无需额外 API Key）
# TTS_PROVIDER 留空或 auto 时优先 edge；可选 edge | glm | openai | browser
TTS_PROVIDER=""

# 服务端 TTS 结果 MP3 内存缓存条数（相同文案+参数重复请求时明显变快，默认 300）
# TTS_SERVER_CACHE_MAX=300

# Edge 在线 TTS（服务端直连微软语音接口；无需付费 Key，但若微软更新校验需可调）
# EDGE_TTS_VOICE="zh-CN-XiaoxiaoNeural"
# EDGE_TTS_RATE="-5%"
# EDGE_TTS_PITCH="+0Hz"
# EDGE_TTS_VOLUME="+0%"
# EDGE_TTS_CHROMIUM_VERSION="143.0.3650.75"
# EDGE_TTS_TRUSTED_TOKEN="6A5AA1D4EAFF4E9FB37E23D68491D6F4"

# 可选：若改用其它云 TTS
# GLM_TTS_VOICE="female"
# GLM_TTS_SPEED="1.0"
# GLM_TTS_VOLUME="1.0"
# OPENAI_TTS_MODEL="tts-1"
# OPENAI_TTS_VOICE="nova"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
